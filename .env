PORT=3000
NODE_ENV=development
PDF_FOLDER=./data/pdfs
EMBEDDINGS_FILE=./data/embeddings.json
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHUNK_SIZE=300
CHUNK_OVERLAP=75
TOP_K=5
# LLM para generación (distinto al modelo de embeddings)
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-r1:8b

# Solo necesitas la key del provider que uses
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=